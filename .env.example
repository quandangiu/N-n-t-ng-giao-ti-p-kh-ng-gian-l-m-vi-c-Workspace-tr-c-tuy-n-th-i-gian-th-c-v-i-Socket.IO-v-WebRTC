# Ví dụ biến môi trường - Sao chép sang .env và chỉnh sửa theo cấu hình của bạn
# Example environment variables - Copy to .env and adjust for your setup

# IP địa chỉ máy chạy server
# Dùng 192.168.1.7 để điện thoại kết nối qua LAN
# Dùng localhost nếu chạy cùng máy
VITE_SERVER_IP=localhost
VITE_SERVER_PORT=3000
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
